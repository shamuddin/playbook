# ============================================
# PLAYBOOK Environment Configuration (Example)
# Copy this file to .env and fill in your values
# ============================================

# Core
ENVIRONMENT=development
DEBUG=false
DEMO_MODE=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/playbooks.db

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
API_PREFIX=/api/v1

# CORS / Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# JWT Authentication (change in production!)
SECRET_KEY=change-me-in-production-min-64-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gemini API (optional)
GEMINI_API_KEY=your-google-ai-studio-key-here
GEMINI_MODEL=gemini-pro

# Lobster Trap DPI
LOBSTERTRAP_BINARY_PATH=./bin/lobstertrap

# Playbooks
PLAYBOOK_DIR=./policies

# Forensics
EVIDENCE_STORE_PATH=./evidence

# Security
SQLCIPHER_KEY=

# Judge Layer
JUDGE_DETERMINISTIC_MODE=true
JUDGE_BYPASS_DETECTION=true

# Policy Builder
POLICY_BUILDER_ENABLED=true
NIST_BASELINE_PATH=./data/nist_baselines.json
ODP_DEFAULTS_PATH=./data/odp_defaults.json
