# ============================================
# PLAYBOOK Environment Configuration
# ============================================

# Core
ENVIRONMENT=development
DEBUG=false
DEMO_MODE=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/playbooks.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=false
API_PREFIX=/api/v1

# CORS / Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# JWT Authentication
SECRET_KEY=change-me-in-production-min-64-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Gemini API (optional, not used in DEMO_MODE)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.2
GEMINI_TIMEOUT_SECONDS=30
GEMINI_CACHE_ENABLED=true
GEMINI_CACHE_PATH=./data/gemini_cache.json

# Lobster Trap DPI
LOBSTERTRAP_BINARY_PATH=./bin/lobstertrap
LOBSTERTRAP_LOG_DIR=./logs/lobstertrap
LOBSTERTRAP_POLICY_DIR=./policies
LOBSTERTRAP_CONFIG_PATH=./config/lobstertrap.yaml

# Log Tailer
LOG_DIR=./logs/lobstertrap
LOG_GLOB_PATTERN=events.*.log
LOG_POLL_INTERVAL=0.1
LOG_MAX_BACKFILL_BYTES=1048576

# Detection
ANOMALY_THRESHOLD=25.0
MAX_ANOMALY_SCORE=100.0

# Playbooks
PLAYBOOK_DIR=./policies
PLAYBOOK_AUTO_EXECUTE=true
PLAYBOOK_HUMAN_REVIEW_SLA_MINUTES=30

# Forensics
EVIDENCE_STORE_PATH=./evidence
EVIDENCE_RETENTION_DAYS=2555
FORENSICS_ENABLED=true

# Security
SQLCIPHER_KEY=
RETAIN_FULL_PROMPTS=false

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=10

# Judge Layer
JUDGE_DETERMINISTIC_MODE=true
JUDGE_BYPASS_DETECTION=true

# SupraWall Integration
SUPRAWALL_WEBHOOK_URL=

# Policy Builder
POLICY_BUILDER_ENABLED=true
NIST_BASELINE_PATH=./data/nist_baselines.json
ODP_DEFAULTS_PATH=./data/odp_defaults.json
